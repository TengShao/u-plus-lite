#!/bin/sh
# Pre-commit hook: warn on potentially dangerous untracked files

FORBIDDEN_PATTERN="\.env$|\.env\.|node_modules|\.log$|\.db$|\.db-journal|\.next\/|\.superpowers\/"

echo "Checking for untracked files that should be ignored..."

UNTRACKED=$(git status --porcelain 2>/dev/null | grep "^??" | cut -c4-)
FORBIDDEN_FOUND=""

for file in $UNTRACKED; do
  if echo "$file" | grep -E "$FORBIDDEN_PATTERN" > /dev/null 2>&1; then
    FORBIDDEN_FOUND="$FORBIDDEN_FOUND  $file\n"
  fi
done

if [ -n "$FORBIDDEN_FOUND" ]; then
  echo "\n⚠️  WARNING: The following untracked files match forbidden patterns:"
  echo "$FORBIDDEN_FOUND"
  echo "These should be added to .gitignore before committing."
  echo "Commit anyway? (Ctrl+C to abort, Enter to continue)"
  read -r CONTINUE
fi
